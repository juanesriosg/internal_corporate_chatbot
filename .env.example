# Copy this file to .env for local development.
# Never commit .env or any real API keys.

# Provider mode:
# - local: deterministic no-key answer composer for smoke tests
# - openai: direct OpenAI API
# - azure_openai: Azure OpenAI Service
LLM_PROVIDER=openai

# Direct OpenAI API settings.
# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_TIMEOUT_SECONDS=60

# Azure OpenAI settings.
# Required only when LLM_PROVIDER=azure_openai.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Local prototype paths.
MOCK_DATA_DIR=mock_data
LOCAL_ARTIFACT_DIR=.local
TENANT_ID=default
VECTOR_BACKEND=chroma
CHROMA_COLLECTION=corporate_chunks
LOCAL_EMBEDDING_DIMENSIONS=384
CHUNK_MAX_WORDS=220
CHUNK_OVERLAP_WORDS=45
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATE_COUNT=40

# API protection.
# Keep disabled for simple local tests. Enable only if you want to test local
# Basic Auth against the browser UI or curl.
API_AUTH_ENABLED=false
API_BASIC_USERNAME=
API_BASIC_PASSWORD=

# Comma-separated browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
